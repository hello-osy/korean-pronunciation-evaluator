checkpoints/
models/
weights/
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin

# =========================
# HuggingFace / Torch cache
# =========================
.huggingface/
hf_cache/
torch_cache/

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/
*.ipynb

